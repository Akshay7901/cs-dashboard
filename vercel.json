{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bunx vite build --config vite.spa.config.ts",
  "installCommand": "bun install",
  "outputDirectory": "dist-spa",
  "rewrites": [
    {
      "source": "/api/proposals/:path*",
      "destination": "https://api.cambridgescholars.com/api/proposals/:path*"
    },
    { "source": "/(.*)", "destination": "/index.spa.html" }
  ]
}